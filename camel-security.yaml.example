# camel-security — starter recognition config.
#
# `hermes plugins install` copies this file to camel-security.yaml in the plugin
# directory (kept across plugin updates). It ships a useful baseline so common
# setups are covered OUT OF THE BOX — every section below is [EXTENDABLE]: add
# your own entries here, or (better for per-profile setups) in
# <HERMES_HOME>/camel-security.yaml, which is merged on top of this file.
#
# Merging is APPEND-ONLY and fail-open: entries ADD recognition on top of the
# plugin's generic defaults; a broken file or invalid regex is skipped and the
# defaults stay intact. Restart the gateway to apply. Full schema + recipes:
# CONFIGURATION.md.

# [EXTENDABLE] Secret FILES — reading these via terminal (cat/type/Get-Content/
# copy/...) prompts for approval (`secret_read`). Regex fragments. The generic
# defaults already cover auth.json, id_rsa, .ssh/, client_secret, *.pem, *.key.
secret_files:
  - 'google_token'          # Google OAuth token caches (google_token.json etc.)
  - 'google_client_secret'  # Google OAuth client secrets
  - '\.codex'               # OpenAI codex CLI auth (~/.codex/auth.json)
  # - 'wallet\.dat'         # add your own crown-jewel files

# [EXTENDABLE] Sensitive PATHS — write_file here prompts (`secret_file`), and the
# interpreter DENIES tainted plan output here. Appended to the generic matcher
# (.env, .ssh, credential, secret, token, config.yaml, ...).
sensitive_paths:
  - '\.codex'
  # - '\.kube[/\\]'

# [EXTENDABLE] Extra terminal-command rules — checked BEFORE the built-ins, so
# your rules win on overlap. `category` may be an existing one (push, egress,
# exec, secret_read, destructive, config) or a new name (add new names to
# CAMEL_SECURITY_CATEGORIES in .env to make them prompt; otherwise audit-only).
cmd_rules:
  - category: destructive
    pattern: '\bkubectl\s+(delete|drain)\b'
  # - category: egress
  #   pattern: '\baws\s+s3\s+cp\b.*s3://'

# [EXTENDABLE] Web-ingest MCP SERVERS — anything that brings EXTERNAL content
# into context (scraping, search, RSS, mail). Vendor prefix covers all current
# and future tools of that server. Quarantined (plan-only) while the 'web'
# toolset is quarantined. firecrawl_/searxng_ are already generic defaults.
web_mcp_prefixes: []
  # - 'rss_'
  # - 'imap_'

# [EXTENDABLE] Single web-ingest tools by (bare) name, when a prefix is too broad:
web_mcp_tools: []
  # - 'fetch_page'

# [EXTENDABLE] Code-execution MCP tools (classified `exec`). Generic defaults
# already cover execute_code / run_code / run_python / eval_code shapes.
exec_tools: []
  # - 'run_sql'

# [EXTENDABLE] GUI-automation, strict tier: BLIND screen-coordinate actions
# (PyAutoGUI-style). EVERY action prompts, approvals never cache. These names
# cover common takeover/computer-use MCP servers — extend with your server's
# acting tools (perception like `capture_screen` and teardown like `stop_service`
# deliberately stay ungated).
takeover_act_tools:
  - click_element
  - click_xy
  - double_click
  - right_click
  - type_text
  - press_key
  - scroll
  - move

# [EXTENDABLE] GUI-automation, softer tier: element-level UI mutations
# (Windows-UIA-style — the tool knows WHAT it clicks). One approval per session.
desktop_act_tools:
  - invoke_element
  - set_text
  - set_element_value
  - toggle_element
  - select_element
  - select_text
  - expand_collapse_element
  - set_range_value
  - set_focus
  - move_element
  - resize_element
  - window_action
  - launch_application

# [EXTENDABLE] Extra web-ingest tools for a built-in toolset (rarely needed):
toolset_tools: {}
  # web: [my_search]
